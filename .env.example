# Django core
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=django-insecure-change-me-in-production

# Debug / hosts
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Development database (SQLite — no setup needed)
DB_PATH=db.sqlite3

# Production database (PostgreSQL) — set these when using config.settings.prod
# DB_NAME=dashboard
# DB_USER=dashboard_user
# DB_PASSWORD=changeme
# DB_HOST=localhost
# DB_PORT=5432
